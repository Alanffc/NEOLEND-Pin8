PORT=8002

# Persistencia. Vacío => store in-memory (mock, corre standalone).
# Ej.: postgres://neolend:neolend@db-fraud:5432/fraud
DATABASE_URL=

# Event bus RabbitMQ. Vacío => MockEventBus en memoria (no bloquea a nadie).
# Ej.: amqp://neolend:neolend@rabbitmq:5672
AMQP_URL=
EVENT_EXCHANGE=neolend.events

# Data residency (inciso VII): el modelo biométrico corre LOCAL.
# Con on-prem, CLOUD_BIOMETRIC_URL debe quedar vacío o el arranque falla.
DATA_RESIDENCY=on-prem
CLOUD_BIOMETRIC_URL=

# Umbrales de decisión (0..1)
FACE_MATCH_THRESHOLD=0.80
LIVENESS_THRESHOLD=0.60
STOLEN_MATCH_THRESHOLD=0.88
FRAUD_SCORE_THRESHOLD=0.50
VELOCITY_MAX_CHECKS=5
EMBEDDING_DIM=64
